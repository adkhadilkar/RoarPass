# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Anthropic (billing uses THIS key, not a personal account) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- GitHub (public demo repo; must already exist) ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx      # PAT with 'repo' scope
GITHUB_USER=your-github-username
GITHUB_REPO=roarpass-demo                  # existing PUBLIC repo name

# --- Optional: external service stubs for Phase 3/4 (leave blank to use mocks) ---
# DEEPL_API_KEY=
# STRIPE_IDENTITY_KEY=

# --- Phone notifications (optional, free) ---
# Install the ntfy app on your phone, subscribe to an unguessable topic, put it here.
NTFY_TOPIC=roarpass-ak
# NTFY_SERVER=https://ntfy.sh   # override only if self-hosting ntfy

# --- Public deploy (optional; you log in to these yourself, see docs/DEPLOY_PUBLIC.md) ---
# DATABASE_URL is set IN Vercel/Neon, not here. Listed for local seeding only:
# DATABASE_URL=postgresql://...neon.tech/neondb
